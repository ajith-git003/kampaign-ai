# Kampaign.ai — AI-native campaign engine
# Copy this file to .env and fill in your credentials.
# Never commit .env to version control.

# ── App ────────────────────────────────────────────────────────────────────────
DEBUG=false
CORS_ORIGINS=["http://localhost:5173"]

# ── Database — Supabase PostgreSQL ─────────────────────────────────────────────
# Format: postgresql+asyncpg://user:password@host:5432/dbname
DATABASE_URL=postgresql+asyncpg://postgres:password@db.supabase.co:5432/postgres

# ── OpenAI — GPT-4o-mini ───────────────────────────────────────────────────────
# [REQUIRED] All AI features in Kampaign.ai use GPT-4o-mini.
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# ── Meta Marketing API ─────────────────────────────────────────────────────────
# [REQUIRED] Create an app at: https://developers.facebook.com/apps
META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret
# Long-lived user token or system-user token with ads_management permission
META_ACCESS_TOKEN=your_long_lived_access_token
# Format: act_XXXXXXXXXX
META_AD_ACCOUNT_ID=act_XXXXXXXXXX

# ── Google Sheets ──────────────────────────────────────────────────────────────
# [REQUIRED] Download service account JSON from:
# https://console.cloud.google.com/iam-admin/serviceaccounts
# Then share your target sheet with the service account email (Viewer is enough).
GOOGLE_SERVICE_ACCOUNT_JSON=/app/secrets/google_service_account.json

# ── Redis / Celery ─────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
